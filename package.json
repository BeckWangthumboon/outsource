{
  "name": "outsource-cli",
  "version": "0.1.0",
  "description": "A small CLI for Cursor-hosted Cloud Agents",
  "type": "module",
  "bin": { "outsource": "./dist/cli.js" },
  "scripts": {
    "build": "bun build ./src/cli.ts --target=bun --outfile=dist/cli.js && chmod +x dist/cli.js",
    "check": "tsc --noEmit",
    "test": "bun test",
    "verify": "bun run check && bun test && bun run build"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "better-result": "^2.9.2",
    "commander": "^15.0.0",
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
